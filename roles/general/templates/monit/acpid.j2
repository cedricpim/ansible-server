{{ ansible_managed | comment }}

 check process acpid with pidfile "/var/run/acpid.pid"
   group system
   group acpid
   start program = "service acpid start"
   stop program  = "service acpid stop"
   if 5 restarts within 5 cycles then timeout
   depends on acpid_bin
   depends on acpid_rc

 check file acpid_bin with path "/usr/sbin/acpid"
   group acpid
   include /etc/monit/templates/rootbin

 check file acpid_rc with path {{ lib_systemd_directory }}/acpid.service
   group acpid
   include /etc/monit/templates/rootrc
