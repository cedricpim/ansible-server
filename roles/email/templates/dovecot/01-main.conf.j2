{{ ansible_managed | comment }}

# Some general options
protocols = imap sieve
auth_username_chars = abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ01234567890.-_@

# Set max. process size in megabytes. Most of the memory goes to mmap()ing
# files, so it shouldn't harm much even if this limit is set pretty high.
#mail_process_size = 512

# IMAP configuration
protocol imap {
  mail_max_userip_connections = 10
  imap_client_workarounds = delay-newmail tb-extra-mailbox-sep
}

# Authentication
service auth-worker {
  # Forbid to access /etc/shadow
  user = $SET:default_internal_user
}

# Used by netdata
service stats {
  inet_listener {
    address = 127.0.0.1
    port = {{ email_dovecot_stats_port }}
  }

  unix_listener stats-reader {
    user = {{ email_user }}
    group = {{ email_user }}
    mode = 0660
  }

  unix_listener stats-writer {
    user = {{ email_user }}
    group = {{ email_user }}
    mode = 0660
  }
}

service auth {
  # IMPORTANT: Match the path to smtpd_sasl_path of Postfix auth
  unix_listener {{ email_postfix_spool }}/{{ email_smtpd_sasl_path }} {
    group = {{ email_postfix_user }}
    user = {{ email_postfix_user }}
    mode = 0666
  }
}

# LDA configuration
protocol lda {
  postmaster_address = {{ email_webmaster }}@{{ server }}
  mail_plugins = sieve
  quota_full_tempfail = yes
  deliver_log_format = msgid=%{msgid}: %{$}
  rejection_reason = Your message to <%{to}> was automatically rejected:\n%{reason}
}

# Plugins configuration
sieve_script personal {
  path = ~/sieve
  active_path = ~/.dovecot.sieve
}

sieve_script before {
  type = before
  path = {{ email_directory }}/sieve-before
}

sieve_script after {
  type = after
  path = {{ email_directory }}/sieve-after
}

userdb {
  driver = static
  args = uid={{ email_user_uid }} gid={{ email_user_uid }} home={{ email_directory }}/%d/%n
}

# Log all failed authentication attempts
auth_verbose=yes
