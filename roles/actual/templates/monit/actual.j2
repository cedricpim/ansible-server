{{ ansible_managed | comment }}

check process actual.{{ server }} with pidfile {{ webserver_nginx_pidfile }}
  group {{ webserver_nginx_user }}
  start program = "/usr/sbin/service nginx start"
  stop program  = "/usr/sbin/service nginx stop"
  if failed host actual.{{ server }} port 443 protocol https request "/" status = 401 then restart
  if cpu is greater than 40% for 2 cycles then alert
  if cpu > 60% for 5 cycles then restart
  if 10 restarts with 10 cycles then unmonitor

check process actual with matching "node.*actual-app"
  group {{ actual_user }}
  start program = "/usr/sbin/service actual start"
  stop program  = "/usr/sbin/service actual stop"
  if failed host localhost port {{ actual_port }} protocol http request "/" status = 200 then restart
  if 5 restarts with 5 cycles then unmonitor
  depends actual_rc

check file actual_rc with path {{ systemd_directory }}/actual.service
  include /etc/monit/templates/rootrc
